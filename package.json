    "build-storybook": "storybook build",
    "serve": "serve .",
    "dev": "npm run build:tokens && npm run serve"
  },
  "devDependencies": {
    "@storybook/addon-themes": "^8.6.18",
    "@storybook/html-vite": "^8.6.0",
    "@tokens-studio/sd-transforms": "^1.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "serve": "^14.2.4",
    "storybook": "^8.6.0",
    "style-dictionary": "^4.2.0",
    "vite": "^5.4.0"
  }
}
