{
  "name": "designtocode-test",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:tokens": "node build-tokens.js",
    "build:netlify": "npm run build:tokens && storybook build --output-dir storybook-static && mkdir -p dist && cp index.html dist/ && cp -r build dist/ && cp -r storybook-static dist/storybook",
